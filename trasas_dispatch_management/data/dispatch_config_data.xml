<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Urgency levels -->
        <record id="urgency_normal" model="trasas.dispatch.urgency">
            <field name="name">Thường</field>
            <field name="sequence">10</field>
            <field name="color">0</field>
        </record>
        <record id="urgency_urgent" model="trasas.dispatch.urgency">
            <field name="name">Khẩn</field>
            <field name="sequence">20</field>
            <field name="color">2</field>
        </record>
        <record id="urgency_very_urgent" model="trasas.dispatch.urgency">
            <field name="name">Hỏa tốc</field>
            <field name="sequence">30</field>
            <field name="color">1</field>
        </record>

        <!-- Default Locations -->
        <record id="location_cabinet_a1" model="trasas.dispatch.location">
            <field name="name">Tủ A1 - Tầng 1</field>
        </record>
        <record id="location_cabinet_a2" model="trasas.dispatch.location">
            <field name="name">Tủ A2 - Tầng 1</field>
        </record>
        <record id="location_cabinet_hcns" model="trasas.dispatch.location">
            <field name="name">Phòng HCNS</field>
        </record>
    </data>
</odoo>
