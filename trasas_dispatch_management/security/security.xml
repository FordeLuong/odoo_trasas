<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Category -->
        <record id="module_category_dispatch_management" model="ir.module.category">
            <field name="name">Quản lý Công văn</field>
            <field name="sequence">10</field>
        </record>

        <!-- Privilege -->
        <record id="privilege_dispatch_management" model="res.groups.privilege">
            <field name="name">Loại quyền</field>
            <field name="category_id" ref="module_category_dispatch_management"/>
            <field name="sequence">10</field>
        </record>

        <!-- Groups -->
        <!-- Group 5: Dispatch Viewer (Người xem) -->
        <record id="group_dispatch_viewer" model="res.groups">
            <field name="name">Dispatch Viewer (Người xem)</field>
            <field name="privilege_id" ref="privilege_dispatch_management"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Chỉ xem thông tin tra cứu.</field>
            <field name="sequence">5</field>
        </record>

        <!-- Group 4: Dispatch User (Nhân viên nghiệp vụ) -->
        <record id="group_dispatch_user" model="res.groups">
            <field name="name">Dispatch User (Nhân viên nghiệp vụ)</field>
            <field name="privilege_id" ref="privilege_dispatch_management"/>
            <field name="implied_ids" eval="[(4, ref('group_dispatch_viewer'))]"/>
            <field name="comment">Nhân viên nghiệp vụ: Soạn thảo và theo dõi công văn.</field>
            <field name="sequence">4</field>
        </record>

        <!-- Group 3: Dispatch Reviewer (Quản lý/Trưởng bộ phận) -->
        <record id="group_dispatch_reviewer" model="res.groups">
            <field name="name">Dispatch Reviewer (Quản lý/Trưởng bộ phận)</field>
            <field name="privilege_id" ref="privilege_dispatch_management"/>
            <field name="implied_ids" eval="[(4, ref('group_dispatch_user'))]"/>
            <field name="comment">Quản lý/Trưởng bộ phận: Rà soát, duyệt nội bộ và soạn thảo.</field>
            <field name="sequence">3</field>
        </record>

        <!-- Group 2: Dispatch Coordinator (Văn thư - HCNS) - Cao nhất về vận hành -->
        <record id="group_dispatch_coordinator" model="res.groups">
            <field name="name">Dispatch Coordinator (Văn thư - HCNS)</field>
            <field name="privilege_id" ref="privilege_dispatch_management"/>
            <field name="implied_ids" eval="[(4, ref('group_dispatch_user'))]"/>
            <field name="comment">Phòng HCNS: Đầu mối tiếp nhận, điều phối, cấp số hiệu và đóng dấu.</field>
            <field name="sequence">2</field>
        </record>

        <!-- Group 1: Dispatch Approver (Ban Giám đốc) - Cao nhất về duyệt -->
        <record id="group_dispatch_approver" model="res.groups">
            <field name="name">Dispatch Approver (Ban Giám đốc)</field>
            <field name="privilege_id" ref="privilege_dispatch_management"/>
            <field name="implied_ids" eval="[(4, ref('group_dispatch_user'))]"/>
            <field name="comment">Ban Giám đốc: Chỉ có quyền Xem và Phê duyệt công văn.</field>
            <field name="sequence">1</field>
        </record>

        <!-- Group 0: Dispatch Administrator (Admintrasistor) - Full Access -->
        <record id="group_dispatch_administrator" model="res.groups">
            <field name="name">Dispatch Administrator (Admintrasistor)</field>
            <field name="privilege_id" ref="privilege_dispatch_management"/>
            <field name="implied_ids" eval="[(4, ref('group_dispatch_coordinator'))]"/>
            <field name="comment">Toàn quyền xem, xóa, sửa trên module công văn.</field>
            <field name="sequence">0</field>
        </record>

        <!-- Admin automatically gets all rights via Administrator group -->
        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('group_dispatch_administrator'))]"/>
        </record>

        <!-- Record Rule: Incoming - Coordinator, Approver and Administrator see all -->
        <record id="dispatch_incoming_all_rule" model="ir.rule">
            <field name="name">Incoming Dispatch: All (Coord and Appr and Admin)</field>
            <field name="model_id" ref="model_trasas_dispatch_incoming"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_dispatch_coordinator')), (4, ref('group_dispatch_approver')), (4, ref('group_dispatch_administrator'))]"/>
        </record>

        <!-- Record Rule: Incoming - Reviewer sees assigned or managed dispatches -->
        <record id="dispatch_incoming_reviewer_rule" model="ir.rule">
            <field name="name">Incoming Dispatch: Managed/Assigned (Reviewer)</field>
            <field name="model_id" ref="model_trasas_dispatch_incoming"/>
            <field name="domain_force">['|', ('handler_ids', 'in', [user.id]), ('manager_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_dispatch_reviewer'))]"/>
        </record>

        <!-- Record Rule: Incoming - User sees assigned dispatches -->
        <record id="dispatch_incoming_user_rule" model="ir.rule">
            <field name="name">Incoming Dispatch: Assigned Only (User)</field>
            <field name="model_id" ref="model_trasas_dispatch_incoming"/>
            <field name="domain_force">[('handler_ids', 'in', [user.id])]</field>
            <field name="groups" eval="[(4, ref('group_dispatch_user'))]"/>
        </record>
    </data>
</odoo>
