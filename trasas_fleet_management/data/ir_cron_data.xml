<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
    <record id="ir_cron_check_vehicle_deadlines" model="ir.cron">
        <field name="name">Fleet: Check Vehicle Deadlines and Maintenance</field>
        <field name="model_id" ref="fleet.model_fleet_vehicle"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_deadlines()</field>
        <field name="nextcall" eval="DateTime.now().replace(hour=0, minute=0, second=0) + timedelta(days=1)"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

    <record id="ir_cron_check_document_expiry" model="ir.cron">
        <field name="name">Fleet: Check Document Expiry</field>
        <field name="model_id" ref="trasas_fleet_management.model_fleet_legal_document"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_document_expiry()</field>
        <field name="nextcall" eval="DateTime.now().replace(hour=0, minute=0, second=0) + timedelta(days=1)"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>
    </data>
</odoo>

