<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Maintenance Types -->
        <record id="fleet_maintenance_type_3m" model="fleet.maintenance.type">
            <field name="name">Gói 3 tháng</field>
            <field name="months">3</field>
        </record>
        <record id="fleet_maintenance_type_6m" model="fleet.maintenance.type">
            <field name="name">Gói 6 tháng</field>
            <field name="months">6</field>
        </record>
        <record id="fleet_maintenance_type_12m" model="fleet.maintenance.type">
            <field name="name">Gói 12 tháng</field>
            <field name="months">12</field>
        </record>

        <!-- Legal Document Types -->
        <record id="fleet_document_type_registration" model="fleet.legal.document.type">
            <field name="name">Giấy đăng ký xe</field>
            <field name="code">REG</field>
            <field name="sequence">10</field>
            <field name="is_mandatory">True</field>
        </record>
        <record id="fleet_document_type_inspection" model="fleet.legal.document.type">
            <field name="name">Phiếu đăng kiểm</field>
            <field name="code">INS</field>
            <field name="sequence">20</field>
            <field name="is_mandatory">True</field>
        </record>
        <record id="fleet_document_type_insurance" model="fleet.legal.document.type">
            <field name="name">Bảo hiểm xe</field>
            <field name="code">INSUR</field>
            <field name="sequence">30</field>
            <field name="is_mandatory">True</field>
        </record>
        <record id="fleet_document_type_license" model="fleet.legal.document.type">
            <field name="name">Giấy tờ biển số</field>
            <field name="code">LICENSE</field>
            <field name="sequence">40</field>
            <field name="is_mandatory">True</field>
        </record>
        <record id="fleet_document_type_ownership" model="fleet.legal.document.type">
            <field name="name">Chứng nhận sở hữu</field>
            <field name="code">OWN</field>
            <field name="sequence">50</field>
        </record>
    </data>
</odoo>
