<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_asset_renovation_wizard_form" model="ir.ui.view">
        <field name="name">trasas.asset.renovation.wizard.form</field>
        <field name="model">trasas.asset.renovation.wizard</field>
        <field name="arch" type="xml">
            <form string="Cai tao">
                <group>
                    <field name="asset_id" invisible="1"/>
                </group>
                <group>
                    <group>
                        <field name="name"/>
                        <field name="start_date"/>
                        <field name="finish_date"/>
                        <field name="amount"/>
                        <field name="currency_id"/>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </group>
                <footer>
                    <button string="Xac nhan" name="action_confirm_renovation" type="object" class="btn-primary"/>
                    <button string="Huy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
