<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_trasas_dispatch_incoming_form_inherit_outgoing" model="ir.ui.view">
        <field name="name">trasas.dispatch.incoming.form.inherit.outgoing</field>
        <field name="model">trasas.dispatch.incoming</field>
        <field name="inherit_id" ref="trasas_dispatch_management.view_trasas_dispatch_incoming_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_create_outgoing_dispatch" 
                        string="Tạo CV đi phản hồi" 
                        type="object" 
                        class="oe_highlight" 
                        invisible="not response_required or outgoing_dispatch_count > 0 or state not in ('processing', 'waiting_confirmation')"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">

                <button name="action_view_outgoing_dispatches"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-share"
                        invisible="outgoing_dispatch_count == 0">
                    <field name="outgoing_dispatch_count" widget="statinfo" string="Công văn đi"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
