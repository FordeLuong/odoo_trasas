<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Rule: Outgoing - User sees own drafts or requests assigned to them -->
        <record id="dispatch_outgoing_user_rule" model="ir.rule">
            <field name="name">Outgoing Dispatch: Own and Assigned</field>
            <field name="model_id" ref="model_trasas_dispatch_outgoing"/>
            <field name="domain_force">['|', ('drafter_id', '=', user.id), ('approver_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('trasas_dispatch_management.group_dispatch_user'))]"/>
        </record>

        <!-- Coordinator, Approver and Reviewer see all for transparency or management -->
        <record id="dispatch_outgoing_all_rule" model="ir.rule">
            <field name="name">Outgoing Dispatch: All</field>
            <field name="model_id" ref="model_trasas_dispatch_outgoing"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('trasas_dispatch_management.group_dispatch_coordinator')), (4, ref('trasas_dispatch_management.group_dispatch_approver')), (4, ref('trasas_dispatch_management.group_dispatch_reviewer')), (4, ref('trasas_dispatch_management.group_dispatch_administrator'))]"/>
        </record>
    </data>
</odoo>
