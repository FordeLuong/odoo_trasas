<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_contract_draft_wizard_form" model="ir.ui.view">
        <field name="name">trasas.contract.draft.wizard.form</field>
        <field name="model">trasas.contract.draft.wizard</field>
        <field name="arch" type="xml">
            <form string="Yêu cầu đưa Hợp đồng về nháp">
                <group>
                    <field name="contract_id" invisible="1"/>
                    <field name="reason" placeholder="Nhập lý do chi tiết tại sao cần đưa hợp đồng này về nháp..."/>
                </group>
                <footer>
                    <div class="alert alert-warning" role="alert" style="margin-bottom:0px;">
                        <i class="fa fa-info-circle"/> Yêu cầu này sẽ được gửi tới Trưởng phòng và Ban Giám đốc để phê duyệt. Hợp đồng chỉ được đặt về nháp sau khi tất cả các cấp đã duyệt.
                    </div>
                </footer>
                <footer>
                    <button string="Gửi yêu cầu" 
                            name="action_confirm_draft_request" 
                            type="object" 
                            class="btn-primary" 
                            data-hotkey="q"/>
                    <button string="Bỏ qua" 
                            class="btn-secondary" 
                            special="cancel" 
                            data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_contract_draft_wizard" model="ir.actions.act_window">
        <field name="name">Yêu cầu đặt về nháp</field>
        <field name="res_model">trasas.contract.draft.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
