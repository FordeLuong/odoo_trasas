<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============ CONTRACT TAGS ============ -->
    <record id="trasas_contract_tag_view_list" model="ir.ui.view">
        <field name="name">trasas.contract.tag.list</field>
        <field name="model">trasas.contract.tag</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_contract_tag" model="ir.actions.act_window">
        <field name="name">Thẻ hợp đồng</field>
        <field name="res_model">trasas.contract.tag</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo thẻ hợp đồng mới.
            </p>
        </field>
    </record>
</odoo>
