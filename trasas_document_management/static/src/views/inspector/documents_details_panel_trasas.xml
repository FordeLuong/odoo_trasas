<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <!-- OWL Component Patch cho Cột Phải (Inspector) của app Documents -->
    <t t-inherit="documents.DocumentsDetailsPanel" t-inherit-mode="extension">
        
        <!-- Chèn khung TRASAS vào sau div o_documents_details_panel_fields của core để không phá vỡ layout nth-child của CSS -->
        <xpath expr="//div[hasclass('o_documents_details_panel_fields')]" position="after">
            
            <t t-if="record.data.type !== 'folder'">

                <!-- BANNER: Tài liệu đã thu hồi -->
                <t t-if="record.data.doc_state === 'revoked'">
                    <div class="w-100 mt-3 p-3 border border-danger rounded bg-danger-subtle text-center">
                        <i class="fa fa-ban fa-2x text-danger mb-2 d-block"/>
                        <p class="mb-0 fw-bold text-danger" style="font-size: 1.1em;">TÀI LIỆU ĐÃ THU HỒI</p>
                        <p class="mb-0 text-muted small">Vui lòng không sử dụng phiên bản tài liệu này.</p>
                    </div>
                </t>

                <!-- BANNER: Yêu cầu truy cập (khi chưa có quyền và KHÔNG phải bị thu hồi) -->
                <t t-else="">
                    <t t-if="!record.data.can_access_content">
                        <div class="w-100 mt-3 p-3 border border-warning rounded bg-warning-subtle text-center">
                            <i class="fa fa-lock fa-2x text-warning mb-2 d-block"/>
                            <p class="mb-2 fw-bold text-dark">Tài liệu này ở chế độ Giới hạn</p>
                            <p class="mb-2 text-muted small">Bạn cần được chủ sở hữu cấp quyền để xem nội dung.</p>
                            <button class="btn btn-warning btn-sm fw-bold"
                                    t-on-click="() => this.onRequestAccess()">
                                <i class="fa fa-key me-1"/>Xin quyền truy cập
                            </button>
                        </div>
                    </t>
                </t>

                <!-- THÔNG TIN HỒ SƠ — Chỉ hiện khi có quyền truy cập nội dung -->
                <t t-if="record.data.can_access_content">
                <!-- TIÊU ĐỀ SECTION -->
                <div class="w-100 mt-4 mb-2 border-bottom border-secondary d-flex align-items-center pb-2">
                    <i class="fa fa-id-card-o text-primary me-2"/>
                    <b class="text-primary text-uppercase" style="font-size: 0.9em;">Thông tin Hồ sơ TRASAS</b>
                </div>

                <div class="o_documents_details_panel_fields d-flex flex-row flex-wrap align-items-baseline w-100">
                    <!-- Số hiệu văn bản -->
                    <i class="fa fa-hashtag mx-1 my-2"/>
                    <div class="o_field_widget o_field_char">
                        <CharField
                            name="'document_number'"
                            record="record"
                            readonly="!record.data.is_owner"
                            placeholder="'Số hiệu...'"
                        />
                    </div>

                    <!-- Ngày cấp -->
                    <i class="fa fa-calendar mx-1 my-2"/>
                    <div class="o_field_widget o_field_date">
                        <DateTimeField
                            name="'issue_date'"
                            record="record"
                            readonly="!record.data.is_owner"
                        />
                    </div>

                    <!-- Ngày hết hiệu lực -->
                    <i class="fa fa-calendar-times-o mx-1 my-2"/>
                    <div class="o_field_widget o_field_date">
                        <DateTimeField
                            name="'validity_date'"
                            record="record"
                            readonly="!record.data.is_owner"
                        />
                    </div>

                    <!-- Số ngày còn lại (Readonly) -->
                    <i class="fa fa-hourglass-half mx-1 my-2"/>
                    <div class="o_field_widget o_field_integer d-flex align-items-center">
                        <IntegerField
                            name="'days_to_expire'"
                            record="record"
                            readonly="true"
                        />
                        <span class="ms-1 text-muted" style="font-size: 0.9em;">ngày</span>
                    </div>

                    <!-- Độ Mật (với popup xác nhận) — Chỉ owner chỉnh -->
                    <i class="fa fa-shield mx-1 my-2"/>
                    <div class="o_field_widget o_field_selection d-flex align-items-center">
                        <ConfidentialLevelField
                            name="'confidential_level'"
                            record="record"
                            readonly="!record.data.is_owner"
                        />
                    </div>

                    <!-- Trạng thái (Badge/Selection) -->
                    <i class="fa fa-info-circle mx-1 my-2"/>
                    <div class="o_field_widget o_field_selection">
                        <SelectionField
                            name="'doc_state'"
                            record="record"
                            readonly="true"
                        />
                    </div>

                    <!-- Phòng ban quản lý -->
                    <i class="fa fa-sitemap mx-1 my-2"/>
                    <div class="o_field_widget o_field_many2one">
                        <DocumentsDetailsMany2OneField
                            name="'department_id'"
                            record="record"
                            readonly="!record.data.is_owner"
                            canOpen="false"
                            canCreate="false"
                            canQuickCreate="false"
                            canCreateEdit="false"
                            placeholder="'Phòng ban...'"
                        />
                    </div>

                    <!-- Người phụ trách -->
                    <i class="fa fa-user-circle-o mx-1 my-2"/>
                    <div class="o_field_widget o_field_many2one">
                        <DocumentsDetailsMany2OneField
                            name="'responsible_user_id'"
                            record="record"
                            readonly="!record.data.is_owner"
                            canOpen="false"
                            canCreate="false"
                            canQuickCreate="false"
                            canCreateEdit="false"
                            placeholder="'Người phụ trách...'"
                        />
                    </div>
                </div>
                </t>
            </t>

        </xpath>
    </t>
</templates>
