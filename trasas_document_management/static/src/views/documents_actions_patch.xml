<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-inherit="documents.DocumentsAction" t-inherit-mode="extension">
        <xpath expr="//button[@t-foreach='firstEmbeddedActions']" position="replace">
            <button t-foreach="firstEmbeddedActions" t-as="action" t-key="action_index" 
                t-attf-class="btn #{action.cssClass || 'btn-secondary'}"
                t-on-click="() => action.callback()" t-esc="action.description" />
        </xpath>
        <xpath expr="//li[@t-foreach='lastEmbeddedActions']/button" position="replace">
            <button type="button" t-attf-class="dropdown-item btn mx-1 #{action.cssClass || 'btn-secondary'}" t-out="action.description"
                t-on-click="() => action.callback()"/>
        </xpath>
    </t>
</templates>
