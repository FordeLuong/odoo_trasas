<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============ PRIVILEGE (Odoo 19) ============ -->
    <record id="privilege_trasas_document" model="res.groups.privilege">
        <field name="name">Quản lý Hồ sơ &amp; Tài liệu</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
        <field name="sequence">25</field>
    </record>

    <!-- ============ SECURITY GROUPS ============ -->

    <!-- Nhóm quyền: Nhân viên (Xem) -->
    <record id="group_doc_user" model="res.groups">
        <field name="name">DMS Internal User (Xem)</field>
        <field name="privilege_id" ref="privilege_trasas_document"/>
        <field name="comment">Tất cả nhân viên nội bộ: Chỉ có quyền Xem tài liệu</field>
    </record>

    <!-- Nhóm quyền: HCNS Manager (Toàn quyền) -->
    <record id="group_doc_manager" model="res.groups">
        <field name="name">DMS HCNS Manager (Toàn quyền)</field>
        <field name="privilege_id" ref="privilege_trasas_document"/>
        <field name="implied_ids" eval="[(4, ref('group_doc_user'))]"/>
        <field name="comment">HCNS (Lai, Kiều): CRUD tất cả tài liệu, Cấu hình, Truy cập</field>
    </record>

    <!-- Nhóm quyền: Ban Giám đốc -->
    <record id="group_doc_director" model="res.groups">
        <field name="name">Ban Giám đốc (DMS)</field>
        <field name="privilege_id" ref="privilege_trasas_document"/>
        <field name="implied_ids" eval="[(4, ref('group_doc_user'))]"/>
        <field name="comment">Xem tất cả tài liệu, Không cần gửi yêu cầu - Bypass phê duyệt</field>
    </record>

    <!-- Admin tự động có quyền Manager -->
    <record id="base.group_system" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_doc_manager'))]"/>
    </record>
</odoo>
